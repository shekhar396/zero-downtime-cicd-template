# Example environment file for local planning and future template usage.
# Do not store real secrets in this file.

APP_NAME=example-app
APP_PORT=3000
HEALTH_CHECK_PATH=/health

DEPLOY_ENV=staging
ACTIVE_COLOR=blue
INACTIVE_COLOR=green

DOCKER_IMAGE=registry.example.com/team/example-app
DOCKER_TAG=0.1.0-alpha

NGINX_UPSTREAM_CONFIG=/etc/nginx/conf.d/example-app-upstream.conf
RELEASE_STATE_FILE=/var/lib/zero-downtime-cicd/release-state.json

