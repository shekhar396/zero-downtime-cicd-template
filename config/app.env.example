# Application identity used by deployment scripts and documentation.
APP_NAME=demo-app

# Docker container names for each deployment color.
BLUE_CONTAINER=demo-blue
GREEN_CONTAINER=demo-green

# Host ports mapped to each color's application container.
BLUE_PORT=8001
GREEN_PORT=8002

# Current traffic target. The idle environment is the opposite color.
ACTIVE_ENV=blue

# HTTP endpoint used to validate a candidate environment before promotion.
HEALTH_ENDPOINT=/health
